# Radar Puls API - Production Environment (non-secret defaults)

# Core
NODE_ENV=production
PORT=3000

# Database (override with secret on server if different)
DATABASE_URL=postgres://postgres:change-this-db-password@db:5432/radar_puls

# Required app secrets (keep real values only on the server)
DEVICE_TOKENS_JSON={"android_listener_01":"replace-with-real-token"}
OPENAI_API_KEY=replace-with-openai-key
OPENAI_MODEL=gpt-5-mini
GOOGLE_GEOCODING_API_KEY=replace-with-google-geocoding-key
GOOGLE_GEOCODING_DELAY_MS=0

# Processing / enrichment
GEO_ENABLED=true
WORKER_BATCH_SIZE=100
WORKER_POLL_INTERVAL_MS=5000
WORKER_LEASE_TIMEOUT_MS=300000
WORKER_MAX_RETRIES=3
WORKER_INSTANCE_ID=worker-1
ENRICHMENT_POLL_INTERVAL_MS=10000
ENRICHMENT_BATCH_SIZE=10
ENRICHMENT_MAX_ATTEMPTS=3
ENRICHMENT_RETRY_COOLDOWN_MS=60000
PARSER_VERSION=v1.0

# Security / public APIs
CORS_ORIGIN=https://radarpuls.com,https://api.radarpuls.com
ADMIN_API_TOKEN=replace-with-long-random-admin-token
RECAPTCHA_SECRET_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:alerts@radarpuls.com
FCM_PROJECT_ID=radar-puls-7e634
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
ANDROID_SHA256_FINGERPRINT=
APPLE_TEAM_ID=
APP_MIN_VERSION=1.0.0
APP_LATEST_VERSION=1.0.0
APP_MAINTENANCE_MODE=false
APP_MAINTENANCE_MESSAGE=
APP_FORCE_UPDATE_MESSAGE=Potrebno je azuriranje aplikacije za nastavak koriscenja.
APP_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.radarpuls.app
APP_APPLE_STORE_URL=https://apps.apple.com/app/radar-puls/id123456789
APP_ANNOUNCEMENT_TEXT=
APP_ANNOUNCEMENT_TYPE=info
APP_ANNOUNCEMENT_URL=
APP_ANNOUNCEMENT_ID=default
APP_ANNOUNCEMENT_DISMISSIBLE=true

# Keep development-only triggers disabled in production
ENABLE_DEV_PROCESSING_TRIGGER=false
PROCESSING_DEV_TRIGGER_TOKEN=
ENABLE_BACKFILL=false
BACKFILL_TRIGGER_TOKEN=

# Postgres service vars used by docker-compose.prod.yml
POSTGRES_DB=radar_puls
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-db-password

# Image consumed by docker-compose.prod.yml
APP_IMAGE=ghcr.io/owner/repo:latest

# Nginx + TLS edge variables (used by docker-compose.edge.yml)
DOMAIN=radarpuls.com
LETSENCRYPT_EMAIL=admin@radarpuls.com
